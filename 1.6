class Solution:
    def maxActiveArea(self, grid):
        """
        grid: 2D list
        return: max active area
        """

        if not grid or not grid[0]:
            return 0

        rows = len(grid)
        cols = len(grid[0])
        visited = set()
        max_area = 0

        for r in range(rows):
            for c in range(cols):
                if (r, c) not in visited:
                    area = self.bfs(grid, r, c, visited)
                    max_area = max(max_area, area)

        return max_area

    def bfs(self, grid, start_r, start_c, visited):
        rows = len(grid)
        cols = len(grid[0])

        queue = [(start_r, start_c)]
        visited.add((start_r, start_c))

        area = 0
        directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]

        while queue:
            r, c = queue.pop(0)
            area += 1

            for dr, dc in directions:
                nr = r + dr
                nc = c + dc

                # Check boundary
                if nr < 0 or nr >= rows or nc < 0 or nc >= cols:
                    continue

                # Check visited
                if (nr, nc) in visited:
                    continue

                # Check value difference
                if abs(grid[nr][nc] - grid[r][c]) <= 1:
                    visited.add((nr, nc))
                    queue.append((nr, nc))

        return area
