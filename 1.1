class Solution:
    def getNthNumber(self, M, N):
        """
        M: 每次查看前 M 个数
        N: 要求第 N 项，N 从 1 开始
        return: 数列第 N 项
        """

        # 创建数组，至少要能保存到第 N 项
        arr = [0] * max(M, N)

        # 初始化前 M 项：1, 2, 3, ..., M
        for i in range(M):
            arr[i] = i + 1

        # 如果 N 在前 M 项内，直接返回
        if N <= M:
            return arr[N - 1]

        # 从第 M + 1 项开始生成
        for i in range(M, N):
            # 取当前项前面的 M 个数作为窗口
            window = arr[i - M:i]

            # 判断窗口中是否存在重复数字
            has_duplicate = len(set(window)) < M

            # 找到窗口中的最大值和最小值
            mx = max(window)
            mn = min(window)

            # 如果有重复，当前项 = 最大值 + 最小值
            # 如果没有重复，当前项 = 最大值 - 最小值
            if has_duplicate:
                arr[i] = mx + mn
            else:
                arr[i] = mx - mn

        # 返回第 N 项
        return arr[N - 1]
