class Solution:
    def calculateErrorRate(self, s1, s2):
        """
        s1: compressed original string
        s2: compressed received string
        return: error rate string
        """

        i = 0
        j = 0

        count1 = 0
        count2 = 0
        char1 = ""
        char2 = ""

        error = 0
        total = 0

        while i < len(s1) or j < len(s2) or count1 > 0 or count2 > 0:
            # Read next part
            if count1 == 0:
                count1, char1, i = self.readPart(s1, i)

            # Read next part
            if count2 == 0:
                count2, char2, j = self.readPart(s2, j)

            # Compare same length
            length = min(count1, count2)

            if char1 != char2:
                error += length

            total += length
            count1 -= length
            count2 -= length

        return str(error) + "/" + str(total)

    def readPart(self, s, index):
        # Read number
        count = 0
        while index < len(s) and s[index].isdigit():
            count = count * 10 + int(s[index])
            index += 1

        # Read char
        char = s[index]
        index += 1

        return count, char, index
